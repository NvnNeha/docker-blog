# Copy this file to `.env` on the server and fill in real values.
# Never commit the real .env — only this template.
#
#   cp .env.example .env
#   nano .env

# ---------------------------------------------------------------
# Core Django
# ---------------------------------------------------------------

# Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(60))"
SECRET_KEY=replace-me-with-a-real-secret

# True for local dev, False in production
DEBUG=False

# Comma-separated allowed Host headers.
# Behind an ALB you MUST also allow the instance's private IP: ALB health
# checks hit the target using its private IP as the Host header (ALB does not
# support a custom Host header), so without it /healthz returns HTTP 400 and
# the target is marked unhealthy.
#
# Inject the private IP at boot from EC2 user-data so it stays env-driven and
# works with autoscaling (each instance appends its own IP):
#
#   PRIVATE_IP=$(curl -s -H "X-aws-ec2-metadata-token: $(curl -s -X PUT \
#     http://169.254.169.254/latest/api/token \
#     -H 'X-aws-ec2-metadata-token-ttl-seconds: 60')" \
#     http://169.254.169.254/latest/meta-data/local-ipv4)
#   echo "ALLOWED_HOSTS=your-domain.com,www.your-domain.com,$PRIVATE_IP" >> /path/to/.env
#
# The value below is the static fallback; replace the IP with your own or let
# user-data append it.
ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# Comma-separated full origins (with scheme) for CSRF on prod. Required for
# admin login and all POST forms over HTTPS.
# e.g. https://your-domain.com,https://www.your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ---------------------------------------------------------------
# Database (RDS PostgreSQL)
# Option A: AWS Secrets Manager (production) — set DB_SECRET_NAME
#           and attach an IAM role with secretsmanager:GetSecretValue
# Option B: .env values (local/dev) — leave DB_SECRET_NAME blank
# Leave both blank to fall back to local sqlite (dev only)
# ---------------------------------------------------------------
DB_SECRET_NAME=
AWS_REGION=ap-south-1
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
# Seconds to keep a DB connection open for reuse. Keep 0 on small RDS
# instances (limited max_connections) to avoid "too many connections".
# Only raise this if you front the DB with RDS Proxy / PgBouncer.
DB_CONN_MAX_AGE=0

# ---------------------------------------------------------------
# AWS S3 for static + media (set USE_S3=True to enable)
# Required in production: with DEBUG=False, media uploads are NOT served by
# the app, so USE_S3=True is needed for post images to load.
# Leave the keys blank to use the EC2/ECS instance IAM role (preferred);
# only set them for local testing against S3.
# ---------------------------------------------------------------
USE_S3=True
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=ap-south-1

